# ──────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in your values.
#  After changing any value, RESTART the dev server (npm run dev)
#  because NEXT_PUBLIC_* values are inlined at build time.
# ──────────────────────────────────────────────────────────────

# Health Audit price (number only, no currency symbol).
# Change this one value and it updates across the whole site + checkout.
NEXT_PUBLIC_HEALTH_AUDIT_PRICE=97

# Calendly event link embedded on the Book a Call page.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/health-audit

# Razorpay public key id.
#  - Test:  rzp_test_xxxxxxxxxxxxx
#  - Live:  rzp_live_xxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Razorpay secret key (SERVER ONLY — never prefixed with NEXT_PUBLIC).
# Optional: if set, checkout creates a proper Razorpay Order (recommended).
# If left blank, checkout still works in test mode without an order.
RAZORPAY_KEY_SECRET=

# Coupon code that grants 100% off at checkout (case-insensitive).
NEXT_PUBLIC_FREE_COUPON_CODE=FREEAUDIT

# Support email shown on legal pages.
NEXT_PUBLIC_SUPPORT_EMAIL=support@theathleticindian.com

# Pabbly Connect webhook for VERIFIED PURCHASES (SERVER ONLY).
# Fired ONLY after the server verifies the Razorpay payment signature
# (or a valid 100%-off coupon). Receives the buyer + payment + tracking data.
PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/xxxxx

# Pabbly Connect webhook for the QUIZ / CTA FORM submission (SERVER ONLY).
# Fired the moment the popup form is submitted (top-of-funnel lead), with the
# quiz questions + answers, contact details and all FB-ads tracking params.
FORM_PABBLY_WEBHOOK=https://connect.pabbly.com/webhook-listener/webhook/xxxxx
